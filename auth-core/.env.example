# auth-core 環境變數範本
# 本機：複製成 .env（用 `netlify dev` 會自動載入）
# 正式：設在 Netlify → Site configuration → Environment variables
# 每個專案用自己的一組憑證。

# 必填：簽登入 cookie 的隨機字串（每個專案都要不一樣）
# 產生一組： node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# 只需填「有啟用」的 provider（對應 config.js 的 enabledProviders）

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LINE
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Facebook（要 email 需通過 Meta 審查）
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# 選填：覆寫網站來源（本機測試填 http://localhost:8888；正式環境留空自動判斷）
# SITE_URL=
